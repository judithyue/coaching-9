# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (except .example)
*.tfvars
!*.tfvars.example
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan files
*.tfplan

# Ignore Mac .DS_Store files
.DS_Store

# IDEs
.terraform.lock.hcl
.idea/
*.swp
*.swo
*~
